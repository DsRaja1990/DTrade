import { useState, useEffect } from 'react';
import { 
  TrendingUp, Activity, DollarSign, 
  RefreshCw, AlertTriangle, Zap, BarChart3, Settings, 
  Globe, TestTube, Sparkles, Rocket, Brain
} from 'lucide-react';


interface StrategyMetrics {
  total_trades: number;
  winning_trades: number;
  losing_trades: number;
  total_pnl: number;
  win_rate: number;
  profit_factor: number;
  max_drawdown: number;
  sharpe_ratio: number;
  start_time?: string;
  end_time?: string;
}

interface Strategy {
  name: string;
  status: 'running' | 'stopped' | 'paused' | 'error';
  metrics: StrategyMetrics;
  config: any;
}

interface StrategyData {
  strategies: Record<string, Strategy>;
  total_count: number;
}

interface QSBPConfig {
  capital: number;
  base_long_ratio: number;
  base_short_ratio: number;
  max_daily_loss: number;
  paper_trading: boolean;
  dhan_access_token?: string;
}

interface QSBPStatus {
  is_running: boolean;
  start_time?: string;
  current_capital: number;
  positions_count: number;
  total_trades: number;
  daily_pnl: number;
  long_exposure: number;
  short_exposure: number;
  total_exposure: number;
}

interface RatioConfig {
  capital: number;
  nifty_lots: number;
  banknifty_lots: number;
  sensex_lots: number;
  max_daily_loss: number;
  paper_trading: boolean;
  dhan_access_token?: string;
}

interface RatioStatus {
  enabled: boolean;
  mode: string;
  start_time?: string;
  current_capital: number;
  positions_count: number;
  total_trades: number;
  daily_pnl: number;
  market_status?: any;
}

interface IndexScalpingConfig {
  index: string;
  capital: number;
  risk_percentage: number;
  max_daily_loss: number;
  paper_trading: boolean;
  dhan_client_id?: string;
  dhan_access_token?: string;
}

interface IndexScalpingStatus {
  is_running: boolean;
  paper_running?: boolean;
  live_running?: boolean;
  mode: string;
  index: string;
  start_time?: string;
  current_capital: number;
  positions_count: number;
  total_trades: number;
  daily_pnl: number;
  win_rate: number;
  avg_trade_duration: number;
  service_health?: string;
  dhan_connection?: boolean;
}

interface EquityHVConfig {
  capital: number;
  max_daily_loss: number;
  base_quantity: number;
  paper_trading: boolean;
  hyper_mode_enabled: boolean;
  max_capital_per_trade: number;
  dhan_access_token?: string;
}

interface EquityHVStatus {
  is_running: boolean;
  paper_running?: boolean;
  live_running?: boolean;
  mode: string;
  start_time?: string;
  current_capital: number;
  positions_count: number;
  total_trades: number;
  daily_pnl: number;
  win_rate: number;
  max_drawdown: number;
  circuit_breakers_triggered: number;
  active_stocks: string[];
  service_health?: string;
  dhan_connection?: boolean;
}

type TradingMode = 'paper' | 'live';
type StrategyTab = 'ratio' | 'qsbp' | 'index-scalping' | 'equity-hv';

const StrategiesPage = () => {
  // API Base URLs
  const EQUITY_HV_API_BASE = 'http://localhost:8003';
  const API_BASE_URL = 'http://localhost:8001';
  
  const [strategies, setStrategies] = useState<StrategyData>({ strategies: {}, total_count: 0 });
  const [loading, setLoading] = useState(true);
  const [actionLoading, setActionLoading] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [selectedStrategy, setSelectedStrategy] = useState<string | null>(null);
  const [activeTab, setActiveTab] = useState<StrategyTab>('qsbp');
  const [tradingMode, setTradingMode] = useState<TradingMode>('paper');
  const [qsbpStatus, setQsbpStatus] = useState<QSBPStatus | null>(null);
  const [qsbpLiveStatus, setQsbpLiveStatus] = useState<QSBPStatus | null>(null);
  const [qsbpServiceHealth, setQsbpServiceHealth] = useState<boolean>(false);
  const [serviceError, setServiceError] = useState<string | null>(null);
  const [qsbpConfig, setQsbpConfig] = useState<QSBPConfig>({
    capital: 400000,
    base_long_ratio: 0.65,
    base_short_ratio: 0.35,
    max_daily_loss: 0.03,
    paper_trading: true,
    dhan_access_token: ''
  });

  // Ratio Strategy State
  const [ratioStatus, setRatioStatus] = useState<RatioStatus | null>(null);
  const [ratioLiveStatus, setRatioLiveStatus] = useState<RatioStatus | null>(null);
  const [ratioServiceHealth, setRatioServiceHealth] = useState<boolean>(false);
  const [ratioServiceError, setRatioServiceError] = useState<string | null>(null);
  const [ratioConfig, setRatioConfig] = useState<RatioConfig>({
    capital: 500000,
    nifty_lots: 20,
    banknifty_lots: 30,
    sensex_lots: 50,
    max_daily_loss: 0.03,
    paper_trading: true,
    dhan_access_token: ''
  });

  // Index Scalping Strategy State
  const [indexScalpingStatus, setIndexScalpingStatus] = useState<IndexScalpingStatus | null>(null);
  const [indexScalpingLiveStatus, setIndexScalpingLiveStatus] = useState<IndexScalpingStatus | null>(null);
  const [indexScalpingServiceHealth, setIndexScalpingServiceHealth] = useState<boolean>(false);
  const [indexScalpingServiceError, setIndexScalpingServiceError] = useState<string | null>(null);
  const [indexScalpingConfig, setIndexScalpingConfig] = useState<IndexScalpingConfig>({
    index: 'NIFTY',
    capital: 100000,
    risk_percentage: 2.0,
    max_daily_loss: 0.05,
    paper_trading: true,
    dhan_client_id: '',
    dhan_access_token: ''
  });

  // Equity HV Strategy State
  const [equityHVStatus, setEquityHVStatus] = useState<EquityHVStatus | null>(null);
  const [equityHVLiveStatus, setEquityHVLiveStatus] = useState<EquityHVStatus | null>(null);
  const [equityHVServiceHealth, setEquityHVServiceHealth] = useState<boolean>(false);
  const [equityHVServiceError, setEquityHVServiceError] = useState<string | null>(null);
  const [equityHVConfig, setEquityHVConfig] = useState<EquityHVConfig>({
    capital: 1000000,  // ₹10 lakhs default
    max_daily_loss: 0.05,  // 5% max daily loss
    base_quantity: 1,
    paper_trading: true,
    hyper_mode_enabled: true,
    max_capital_per_trade: 0.25,  // 25% max per trade
    dhan_access_token: ''
  });

  // Strategy status configuration
  const statusConfig = {
    running: { color: 'from-green-500 to-green-600', icon: Activity, text: 'Running' },
    stopped: { color: 'from-gray-500 to-gray-600', icon: Activity, text: 'Stopped' },
    paused: { color: 'from-yellow-500 to-yellow-600', icon: Activity, text: 'Paused' },
    error: { color: 'from-red-500 to-red-600', icon: AlertTriangle, text: 'Error' }
  };

  const fetchStrategies = async () => {
    try {
      const response = await fetch('/api/papertest/strategies');
      if (!response.ok) throw new Error('Failed to fetch strategies');
      const result = await response.json();
      if (result.success) {
        setStrategies(result.data);
      }
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to fetch strategies');
    } finally {
      setLoading(false);
    }
  };

  const toggleStrategy = async (strategyName: string, action: string) => {
    setActionLoading(strategyName);
    try {
      const response = await fetch('/api/papertest/strategies/toggle', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          strategy_name: strategyName,
          action: action
        })
      });

      const result = await response.json();
      if (!result.success) {
        throw new Error(result.message || 'Action failed');
      }

      await fetchStrategies();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Action failed');
    } finally {
      setActionLoading(null);
    }
  };

  const registerRatioStrategy = async () => {
    setActionLoading('register');
    try {
      const response = await fetch('/api/papertest/strategies/register', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          strategy_type: 'ratio_strategy',
          nifty_lots: 20,
          banknifty_lots: 30,
          sensex_lots: 50,
          virtual_capital: 1000000.0,
          max_position_risk: 0.02,
          max_total_risk: 0.10
        })
      });

      const result = await response.json();
      if (!result.success) {
        throw new Error(result.message || 'Registration failed');
      }

      await fetchStrategies();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Registration failed');
    } finally {
      setActionLoading(null);
    }
  };

  // QSBP Strategy Functions
  const fetchQSBPStatus = async () => {
    try {
      const response = await fetch('/api/strategies/qsbp/status');
      if (response.ok) {
        const status = await response.json();
        setQsbpStatus(status);
      }
    } catch (err) {
      console.error('Failed to fetch QSBP status:', err);
    }
  };

  const fetchQSBPLiveStatus = async () => {
    try {
      const response = await fetch('/api/strategies/qsbp/live/status');
      if (response.ok) {
        const status = await response.json();
        setQsbpLiveStatus(status);
      }
    } catch (err) {
      console.error('Failed to fetch QSBP live status:', err);
    }
  };

  const startQSBPStrategy = async () => {
    setActionLoading('start-qsbp');
    try {
      const response = await fetch('/api/strategies/qsbp/start', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(qsbpConfig)
      });

      if (!response.ok) {
        throw new Error('Failed to start QSBP strategy');
      }

      await fetchQSBPStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to start QSBP strategy');
    } finally {
      setActionLoading(null);
    }
  };

  const stopQSBPStrategy = async () => {
    setActionLoading('stop-qsbp');
    try {
      const response = await fetch('/api/strategies/qsbp/stop', {
        method: 'POST'
      });

      if (!response.ok) {
        throw new Error('Failed to stop QSBP strategy');
      }

      await fetchQSBPStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to stop QSBP strategy');
    } finally {
      setActionLoading(null);
    }
  };

  const startQSBPLiveStrategy = async () => {
    setActionLoading('start-qsbp-live');
    try {
      const liveConfig = { ...qsbpConfig, paper_trading: false };
      const response = await fetch('/api/strategies/qsbp/live/start', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(liveConfig)
      });

      if (!response.ok) {
        throw new Error('Failed to start QSBP live strategy');
      }

      await fetchQSBPLiveStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to start QSBP live strategy');
    } finally {
      setActionLoading(null);
    }
  };

  const stopQSBPLiveStrategy = async () => {
    setActionLoading('stop-qsbp-live');
    try {
      const response = await fetch('/api/strategies/qsbp/live/stop', {
        method: 'POST'
      });

      if (!response.ok) {
        throw new Error('Failed to stop QSBP live strategy');
      }

      await fetchQSBPLiveStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to stop QSBP live strategy');
    } finally {
      setActionLoading(null);
    }
  };

  const updateDhanToken = async (token: string) => {
    try {
      const response = await fetch('/api/strategies/qsbp/update-token', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ access_token: token })
      });

      if (!response.ok) {
        throw new Error('Failed to update Dhan token');
      }

      setQsbpConfig(prev => ({ ...prev, dhan_access_token: token }));
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to update Dhan token');
    }
  };

  const updateLiveDhanToken = async (token: string) => {
    try {
      const response = await fetch('/api/strategies/qsbp/live/update-token', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ access_token: token })
      });

      if (!response.ok) {
        throw new Error('Failed to update live Dhan token');
      }

      setQsbpConfig(prev => ({ ...prev, dhan_access_token: token }));
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to update live Dhan token');
    }
  };

  // QSBP Strategy Toggle Function
  const toggleQSBPStrategy = async () => {
    // Check service health first
    await checkServiceHealth();
    
    if (!qsbpServiceHealth) {
      setError(serviceError || 'QSBP service is not running. Please start the service first.');
      return;
    }
    
    const isRunning = getCurrentQSBPStatus()?.is_running;
    
    if (isRunning) {
      // Stop strategy
      if (tradingMode === 'paper') {
        await stopQSBPStrategy();
      } else {
        await stopQSBPLiveStrategy();
      }
    } else {
      // Start strategy
      if (tradingMode === 'paper') {
        await startQSBPStrategy();
      } else {
        await startQSBPLiveStrategy();
      }
    }
  };

  // Check QSBP Service Health
  const checkServiceHealth = async () => {
    try {
      const response = await fetch('/api/strategies/qsbp/service/health');
      if (response.ok) {
        const result = await response.json();
        setQsbpServiceHealth(result.service_running);
        if (!result.service_running) {
          setServiceError(result.message || 'QSBP service is not running');
        } else {
          setServiceError(null);
        }
      } else {
        setQsbpServiceHealth(false);
        setServiceError('Failed to check service health');
      }
    } catch (err) {
      setQsbpServiceHealth(false);
      setServiceError('QSBP service is not available');
    }
  };

  // ===== RATIO STRATEGY FUNCTIONS =====
  
  // Fetch Ratio Strategy Status (Paper)
  const fetchRatioStatus = async () => {
    try {
      const response = await fetch('/api/strategies/ratio/status');
      if (response.ok) {
        const result = await response.json();
        if (result.success) {
          setRatioStatus(result.data);
        }
      }
    } catch (err) {
      console.error('Failed to fetch Ratio status:', err);
    }
  };

  // Fetch Ratio Strategy Status (Live)
  const fetchRatioLiveStatus = async () => {
    try {
      const response = await fetch('/api/strategies/ratio/live/status');
      if (response.ok) {
        const result = await response.json();
        if (result.success) {
          setRatioLiveStatus(result.data);
        }
      }
    } catch (err) {
      console.error('Failed to fetch Ratio live status:', err);
    }
  };

  // Start Ratio Strategy (Paper)
  const startRatioStrategy = async () => {
    setActionLoading('start-ratio');
    try {
      const response = await fetch('/api/strategies/ratio/start', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(ratioConfig)
      });

      const result = await response.json();
      if (!result.success) {
        throw new Error(result.message || 'Failed to start Ratio strategy');
      }

      await fetchRatioStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to start Ratio strategy');
    } finally {
      setActionLoading(null);
    }
  };

  // Stop Ratio Strategy (Paper)
  const stopRatioStrategy = async () => {
    setActionLoading('stop-ratio');
    try {
      const response = await fetch('/api/strategies/ratio/stop', {
        method: 'POST'
      });

      const result = await response.json();
      if (!result.success) {
        throw new Error(result.message || 'Failed to stop Ratio strategy');
      }

      await fetchRatioStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to stop Ratio strategy');
    } finally {
      setActionLoading(null);
    }
  };

  // Start Ratio Strategy (Live)
  const startRatioLiveStrategy = async () => {
    setActionLoading('start-ratio-live');
    try {
      const liveConfig = { ...ratioConfig, paper_trading: false };
      const response = await fetch('/api/strategies/ratio/live/start', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(liveConfig)
      });

      const result = await response.json();
      if (!result.success) {
        throw new Error(result.message || 'Failed to start Ratio live strategy');
      }

      await fetchRatioLiveStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to start Ratio live strategy');
    } finally {
      setActionLoading(null);
    }
  };

  // Stop Ratio Strategy (Live)
  const stopRatioLiveStrategy = async () => {
    setActionLoading('stop-ratio-live');
    try {
      const response = await fetch('/api/strategies/ratio/live/stop', {
        method: 'POST'
      });

      const result = await response.json();
      if (!result.success) {
        throw new Error(result.message || 'Failed to stop Ratio live strategy');
      }

      await fetchRatioLiveStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to stop Ratio live strategy');
    } finally {
      setActionLoading(null);
    }
  };

  // Update Dhan Token for Ratio Strategy (Paper)
  const updateRatioDhanToken = async (token: string) => {
    try {
      const response = await fetch('/api/strategies/ratio/update-token', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ access_token: token })
      });

      const result = await response.json();
      if (!result.success) {
        throw new Error(result.message || 'Failed to update Dhan token');
      }

      setRatioConfig(prev => ({ ...prev, dhan_access_token: token }));
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to update Dhan token');
    }
  };

  // Update Dhan Token for Ratio Strategy (Live)
  const updateRatioLiveDhanToken = async (token: string) => {
    try {
      const response = await fetch('/api/strategies/ratio/live/update-token', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ access_token: token })
      });

      const result = await response.json();
      if (!result.success) {
        throw new Error(result.message || 'Failed to update live Dhan token');
      }

      setRatioConfig(prev => ({ ...prev, dhan_access_token: token }));
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to update live Dhan token');
    }
  };

  // Ratio Strategy Toggle Function
  const toggleRatioStrategy = async () => {
    // Check service health first for live mode
    if (tradingMode === 'live') {
      await checkRatioServiceHealth();
      
      if (!ratioServiceHealth) {
        setError(ratioServiceError || 'Ratio service is not running. Please start the service first.');
        return;
      }
    }
    
    const isRunning = getCurrentRatioStatus()?.enabled;
    
    if (isRunning) {
      // Stop strategy
      if (tradingMode === 'paper') {
        await stopRatioStrategy();
      } else {
        await stopRatioLiveStrategy();
      }
    } else {
      // Start strategy
      if (tradingMode === 'paper') {
        await startRatioStrategy();
      } else {
        await startRatioLiveStrategy();
      }
    }
  };

  // Check Ratio Service Health
  const checkRatioServiceHealth = async () => {
    try {
      const response = await fetch('/api/strategies/ratio/service/health');
      if (response.ok) {
        const result = await response.json();
        setRatioServiceHealth(result.service_available);
        if (!result.service_available) {
          setRatioServiceError(result.message || 'Ratio service is not running');
        } else {
          setRatioServiceError(null);
        }
      } else {
        setRatioServiceHealth(false);
        setRatioServiceError('Failed to check service health');
      }
    } catch (err) {
      setRatioServiceHealth(false);
      setRatioServiceError('Ratio service is not available');
    }
  };

  // Get current ratio status based on trading mode
  const getCurrentRatioStatus = () => {
    return tradingMode === 'paper' ? ratioStatus : ratioLiveStatus;
  };

  // Index Scalping Strategy Functions
  const fetchIndexScalpingStatus = async () => {
    try {
      const response = await fetch('/api/strategies/index-scalping/status');
      if (response.ok) {
        const result = await response.json();
        if (result.success) {
          // Extract combined status information
          const statusData = result.data;
          const combinedStatus = {
            is_running: statusData.is_running || false,
            paper_running: statusData.paper_trading?.running || false,
            live_running: statusData.live_trading?.running || false,
            service_health: statusData.service_health || 'unknown',
            dhan_connection: statusData.dhan_connection || false,
            // Extract metrics from appropriate engine
            ...((tradingMode === 'paper' ? statusData.paper_trading?.status : statusData.live_trading?.status) || {})
          };
          setIndexScalpingStatus(combinedStatus);
        }
      }
    } catch (err) {
      console.error('Failed to fetch Index Scalping status:', err);
    }
  };

  const startIndexScalpingStrategy = async () => {
    setActionLoading('start-index-scalping');
    try {
      const response = await fetch('/api/strategies/index-scalping/paper-trading/start', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(indexScalpingConfig)
      });

      if (!response.ok) {
        throw new Error('Failed to start Index Scalping strategy');
      }

      await fetchIndexScalpingStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to start Index Scalping strategy');
    } finally {
      setActionLoading(null);
    }
  };

  const stopIndexScalpingStrategy = async () => {
    setActionLoading('stop-index-scalping');
    try {
      const response = await fetch('/api/strategies/index-scalping/paper-trading/stop', {
        method: 'POST'
      });

      if (!response.ok) {
        throw new Error('Failed to stop Index Scalping strategy');
      }

      await fetchIndexScalpingStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to stop Index Scalping strategy');
    } finally {
      setActionLoading(null);
    }
  };

  const startIndexScalpingLiveStrategy = async () => {
    setActionLoading('start-index-scalping-live');
    try {
      const liveConfig = { ...indexScalpingConfig, paper_trading: false };
      const response = await fetch('/api/strategies/index-scalping/live-trading/start', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(liveConfig)
      });

      if (!response.ok) {
        throw new Error('Failed to start Index Scalping live strategy');
      }

      await fetchIndexScalpingStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to start Index Scalping live strategy');
    } finally {
      setActionLoading(null);
    }
  };

  const stopIndexScalpingLiveStrategy = async () => {
    setActionLoading('stop-index-scalping-live');
    try {
      const response = await fetch('/api/strategies/index-scalping/live-trading/stop', {
        method: 'POST'
      });

      if (!response.ok) {
        throw new Error('Failed to stop Index Scalping live strategy');
      }

      await fetchIndexScalpingStatus();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to stop Index Scalping live strategy');
    } finally {
      setActionLoading(null);
    }
  };

  const checkIndexScalpingServiceHealth = async () => {
    try {
      const response = await fetch('/api/strategies/index-scalping/health');
      if (response.ok) {
        const result = await response.json();
        setIndexScalpingServiceHealth(result.status === 'healthy');
        if (result.status !== 'healthy') {
          setIndexScalpingServiceError(result.error || 'Index Scalping service is not running');
        } else {
          setIndexScalpingServiceError(null);
        }
      } else {
        setIndexScalpingServiceHealth(false);
        setIndexScalpingServiceError('Failed to check service health');
      }
    } catch (err) {
      setIndexScalpingServiceHealth(false);
      setIndexScalpingServiceError('Index Scalping service is not available');
    }
  };

  const toggleIndexScalpingStrategy = async () => {
    try {
      setActionLoading('index-scalping');
      setError(null);
      
      await checkIndexScalpingServiceHealth();
      
      if (!indexScalpingServiceHealth) {
        setError(indexScalpingServiceError || 'Index Scalping service is not running. Please start the service first.');
        return;
      }
      
      // Get current status including market status
      const statusResponse = await fetch(`${API_BASE_URL}/strategies/index-scalping/status`);
      const statusData = await statusResponse.json();
      
      if (!statusResponse.ok) {
        throw new Error(statusData.detail || 'Failed to get strategy status');
      }
      
      const isRunning = tradingMode === 'paper' 
        ? statusData.paper_running 
        : statusData.live_running;
      
      // Check market status before starting
      if (!isRunning) {
        const marketStatus = statusData.market_status;
        const websocketConnected = statusData.websocket_connected;
        
        if (marketStatus === 'offline') {
          setError("🚫 Market is currently offline. Trading cannot be started outside market hours (9:15 AM - 3:30 PM).");
          return;
        }
        
        if (!websocketConnected) {
          // Show warning but allow to proceed
          setError("⚠️ Real-time market data feed is unavailable. Trading will use delayed data.");
          // Clear warning after 3 seconds and proceed
          setTimeout(() => setError(null), 3000);
        }
      }
      
      // Proceed with starting/stopping
      if (isRunning) {
        // Stop the currently running mode
        if (tradingMode === 'paper') {
          await stopIndexScalpingStrategy();
        } else {
          await stopIndexScalpingLiveStrategy();
        }
      } else {
        // Start the selected mode
        if (tradingMode === 'paper') {
          await startIndexScalpingStrategy();
        } else {
          await startIndexScalpingLiveStrategy();
        }
      }
      
    } catch (error) {
      console.error('Toggle Index Scalping error:', error);
      setError(`❌ Toggle Error: ${error instanceof Error ? error.message : 'Unknown error occurred'}`);
    } finally {
      setActionLoading(null);
    }
  };

  const getCurrentIndexScalpingStatus = () => {
    return indexScalpingStatus;
  };

  // ===== EQUITY HV STRATEGY FUNCTIONS =====

  const fetchEquityHVStatus = async () => {
    try {
      const response = await fetch(`${EQUITY_HV_API_BASE}/health`);
      if (response.ok) {
        const data = await response.json();
        const engines = data.engines || {};
        
        // Extract paper and live status
        const paperEngine = engines['equity_hv_paper'];
        const liveEngine = engines['equity_hv_live'];
        
        if (paperEngine) {
          setEquityHVStatus({
            is_running: paperEngine.running,
            paper_running: paperEngine.running,
            live_running: false,
            mode: 'paper',
            start_time: paperEngine.uptime,
            current_capital: 0, // Will be updated with performance API
            positions_count: paperEngine.positions || 0,
            total_trades: paperEngine.total_trades || 0,
            daily_pnl: paperEngine.daily_pnl || 0,
            win_rate: paperEngine.win_rate || 0,
            max_drawdown: 0,
            circuit_breakers_triggered: data.summary?.circuit_breakers_triggered || 0,
            active_stocks: ['ADANIENT', 'TRENT', 'BAJFINANCE', 'TATAMOTORS', 'RELIANCE', 'HDFCBANK', 'ICICIBANK', 'ZEEL', 'PNB', 'RBLBANK'],
            service_health: data.status,
            dhan_connection: true
          });
        }
        
        if (liveEngine) {
          setEquityHVLiveStatus({
            is_running: liveEngine.running,
            paper_running: false,
            live_running: liveEngine.running,
            mode: 'live',
            start_time: liveEngine.uptime,
            current_capital: 0,
            positions_count: liveEngine.positions || 0,
            total_trades: liveEngine.total_trades || 0,
            daily_pnl: liveEngine.daily_pnl || 0,
            win_rate: liveEngine.win_rate || 0,
            max_drawdown: 0,
            circuit_breakers_triggered: data.summary?.circuit_breakers_triggered || 0,
            active_stocks: ['ADANIENT', 'TRENT', 'BAJFINANCE', 'TATAMOTORS', 'RELIANCE', 'HDFCBANK', 'ICICIBANK', 'ZEEL', 'PNB', 'RBLBANK'],
            service_health: data.status,
            dhan_connection: true
          });
        }
        
        setEquityHVServiceHealth(data.status === 'healthy');
        setEquityHVServiceError(null);
      }
    } catch (error) {
      console.error('Equity HV status fetch error:', error);
      setEquityHVServiceHealth(false);
      setEquityHVServiceError(error instanceof Error ? error.message : 'Service unavailable');
    }
  };

  const checkEquityHVServiceHealth = async () => {
    try {
      const response = await fetch(`${EQUITY_HV_API_BASE}/health`);
      setEquityHVServiceHealth(response.ok);
      if (!response.ok) {
        setEquityHVServiceError('Service health check failed');
      } else {
        setEquityHVServiceError(null);
      }
    } catch (error) {
      setEquityHVServiceHealth(false);
      setEquityHVServiceError(error instanceof Error ? error.message : 'Service unreachable');
    }
  };

  const startEquityHVPaperStrategy = async () => {
    try {
      const response = await fetch(`${EQUITY_HV_API_BASE}/api/trading/start`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          execution_mode: 'paper',
          capital: equityHVConfig.capital,
          max_daily_loss: equityHVConfig.max_daily_loss,
          quantity: equityHVConfig.base_quantity,
          dhan_access_token: equityHVConfig.dhan_access_token
        })
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.detail || `HTTP ${response.status}`);
      }

      const result = await response.json();
      console.log('Equity HV Paper Strategy started:', result);
      
      // Refresh status after starting
      setTimeout(() => {
        fetchEquityHVStatus();
      }, 2000);
      
    } catch (error) {
      console.error('Start Equity HV Paper error:', error);
      throw error;
    }
  };

  const startEquityHVLiveStrategy = async () => {
    try {
      const response = await fetch(`${EQUITY_HV_API_BASE}/api/trading/start`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          execution_mode: 'live',
          capital: equityHVConfig.capital,
          max_daily_loss: equityHVConfig.max_daily_loss,
          quantity: equityHVConfig.base_quantity,
          dhan_access_token: equityHVConfig.dhan_access_token
        })
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.detail || `HTTP ${response.status}`);
      }

      const result = await response.json();
      console.log('Equity HV Live Strategy started:', result);
      
      // Refresh status after starting
      setTimeout(() => {
        fetchEquityHVStatus();
      }, 2000);
      
    } catch (error) {
      console.error('Start Equity HV Live error:', error);
      throw error;
    }
  };

  const stopEquityHVStrategy = async (mode: 'paper' | 'live') => {
    try {
      const response = await fetch(`${EQUITY_HV_API_BASE}/api/trading/stop`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          execution_mode: mode,
          close_positions: true
        })
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.detail || `HTTP ${response.status}`);
      }

      const result = await response.json();
      console.log(`Equity HV ${mode} Strategy stopped:`, result);
      
      // Refresh status after stopping
      setTimeout(() => {
        fetchEquityHVStatus();
      }, 2000);
      
    } catch (error) {
      console.error(`Stop Equity HV ${mode} error:`, error);
      throw error;
    }
  };

  const toggleEquityHVStrategy = async (mode: 'paper' | 'live') => {
    setActionLoading(`equity-hv-${mode}`);
    try {
      const currentStatus = mode === 'paper' ? equityHVStatus : equityHVLiveStatus;
      const isRunning = currentStatus?.is_running || 
                      (mode === 'paper' ? currentStatus?.paper_running : currentStatus?.live_running);
      
      if (isRunning) {
        await stopEquityHVStrategy(mode);
      } else {
        if (mode === 'paper') {
          await startEquityHVPaperStrategy();
        } else {
          await startEquityHVLiveStrategy();
        }
      }
      
    } catch (error) {
      console.error('Toggle Equity HV error:', error);
      setError(`❌ Toggle Error: ${error instanceof Error ? error.message : 'Unknown error occurred'}`);
    } finally {
      setActionLoading(null);
    }
  };

  const getCurrentEquityHVStatus = () => {
    return tradingMode === 'paper' ? equityHVStatus : equityHVLiveStatus;
  };

  // Auto-refresh status when running
  useEffect(() => {
    let interval: number;
    
    if (qsbpStatus?.is_running || qsbpLiveStatus?.is_running || getCurrentRatioStatus()?.enabled || 
        indexScalpingStatus?.paper_running || indexScalpingStatus?.live_running ||
        equityHVStatus?.is_running || equityHVLiveStatus?.is_running) {
      interval = setInterval(() => {
        fetchQSBPStatus();
        fetchQSBPLiveStatus();
        fetchRatioStatus();
        fetchRatioLiveStatus();
        fetchIndexScalpingStatus();
        fetchEquityHVStatus();
      }, 5000);
    }
    
    return () => {
      if (interval) clearInterval(interval);
    };
  }, [qsbpStatus?.is_running, qsbpLiveStatus?.is_running, ratioStatus?.enabled, ratioLiveStatus?.enabled, 
      indexScalpingStatus?.paper_running, indexScalpingStatus?.live_running,
      equityHVStatus?.is_running, equityHVLiveStatus?.is_running]);

  useEffect(() => {
    fetchStrategies();
    fetchQSBPStatus();
    fetchQSBPLiveStatus();
    checkServiceHealth();
    fetchRatioStatus();
    fetchRatioLiveStatus();
    checkRatioServiceHealth();
    fetchIndexScalpingStatus();
    checkIndexScalpingServiceHealth();
    fetchEquityHVStatus();
    checkEquityHVServiceHealth();
    
    const interval = setInterval(() => {
      fetchStrategies();
      if (activeTab === 'qsbp') {
        fetchQSBPStatus();
        fetchQSBPLiveStatus();
        checkServiceHealth();
      } else if (activeTab === 'ratio') {
        fetchRatioStatus();
        fetchRatioLiveStatus();
        checkRatioServiceHealth();
      } else if (activeTab === 'index-scalping') {
        fetchIndexScalpingStatus();
        checkIndexScalpingServiceHealth();
      }
    }, 10000);

    return () => {
      if (interval) clearInterval(interval);
    };
  }, [activeTab]);

  const formatCurrency = (amount: number) => {
    return new Intl.NumberFormat('en-IN', {
      style: 'currency',
      currency: 'INR',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0
    }).format(amount);
  };

  const formatPercentage = (value: number) => {
    return `${(value * 100).toFixed(2)}%`;
  };

  const getCurrentQSBPStatus = () => {
    return tradingMode === 'paper' ? qsbpStatus : qsbpLiveStatus;
  };

  if (loading && strategies.total_count === 0) {
    return (
      <div className="flex items-center justify-center h-64">
        <div className="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-500"></div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-gray-900 via-blue-900 to-purple-900">
      {/* Compact Header */}
      <div className="bg-black/20 backdrop-blur-sm border-b border-white/10">
        <div className="max-w-7xl mx-auto px-4 py-4">
          <div className="flex justify-between items-center">
            <div className="flex items-center space-x-3">
              <div className="p-2 bg-gradient-to-r from-blue-500 to-purple-500 rounded-lg">
                <Brain className="h-6 w-6 text-white" />
              </div>
              <div>
                <h1 className="text-2xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">
                  Trading Strategies
                </h1>
                <p className="text-gray-400 text-xs">Advanced algorithmic trading systems</p>
              </div>
            </div>
            <div className="flex items-center space-x-3">
              {/* Trading Mode Toggle */}
              <div className="flex items-center space-x-2 bg-black/30 rounded-lg px-3 py-1.5">
                <span className="text-xs text-gray-400 font-medium">Mode:</span>
                <div className="relative">
                  <button
                    onClick={() => setTradingMode(tradingMode === 'paper' ? 'live' : 'paper')}
                    className={`relative w-12 h-6 rounded-full transition-all duration-300 ${
                      tradingMode === 'live' 
                        ? 'bg-gradient-to-r from-red-500 to-red-600' 
                        : 'bg-gradient-to-r from-blue-500 to-blue-600'
                    }`}
                  >
                    <div className={`absolute top-0.5 w-5 h-5 bg-white rounded-full transition-transform duration-300 ${
                      tradingMode === 'live' ? 'translate-x-6' : 'translate-x-0.5'
                    }`} />
                  </button>
                </div>
                <div className="flex items-center space-x-1">
                  {tradingMode === 'paper' ? (
                    <>
                      <TestTube className="h-3 w-3 text-blue-400" />
                      <span className="text-blue-400 font-medium text-xs">Paper</span>
                    </>
                  ) : (
                    <>
                      <Globe className="h-3 w-3 text-red-400" />
                      <span className="text-red-400 font-medium text-xs">Live</span>
                    </>
                  )}
                </div>
              </div>
              
              <button
                onClick={() => {
                  fetchStrategies();
                  if (activeTab === 'qsbp') {
                    fetchQSBPStatus();
                    fetchQSBPLiveStatus();
                  }
                }}
                disabled={loading}
                className="px-3 py-1.5 bg-white/10 backdrop-blur-sm border border-white/20 text-white rounded-lg hover:bg-white/20 disabled:opacity-50 flex items-center space-x-1 transition-all"
              >
                <RefreshCw className={`h-3 w-3 ${loading ? 'animate-spin' : ''}`} />
                <span className="text-xs">Refresh</span>
              </button>
            </div>
          </div>
        </div>
      </div>

      {/* Main Content */}
      <div className="max-w-7xl mx-auto px-4 py-4">
        {/* Compact Strategy Tabs */}
        <div className="mb-4">
          <div className="flex space-x-1 bg-black/20 backdrop-blur-sm rounded-xl p-1 border border-white/10">
            {[
              { id: 'qsbp', name: 'Equity Strategy', icon: Zap, gradient: 'from-purple-500 to-pink-500', disabled: false },
              { id: 'ratio', name: 'Ratio Strategy', icon: TrendingUp, gradient: 'from-blue-500 to-cyan-500', disabled: false },
              { id: 'index-scalping', name: 'Index Scalping', icon: Activity, gradient: 'from-red-500 to-orange-500', disabled: false },
              { id: 'equity-hv', name: 'Equity HV', icon: Rocket, gradient: 'from-orange-500 to-red-500', disabled: false },
              { id: 'neural', name: 'Neural Network', icon: Brain, gradient: 'from-green-500 to-emerald-500', disabled: true }
            ].map((tab) => {
              const TabIcon = tab.icon;
              return (
                <button
                  key={tab.id}
                  onClick={() => !tab.disabled && setActiveTab(tab.id as StrategyTab)}
                  disabled={tab.disabled}
                  className={`flex-1 py-2 px-3 rounded-lg text-sm font-medium transition-all duration-300 relative overflow-hidden ${
                    activeTab === tab.id
                      ? `bg-gradient-to-r ${tab.gradient} text-white shadow-lg shadow-purple-500/25`
                      : tab.disabled
                      ? 'text-gray-500 cursor-not-allowed'
                      : 'text-gray-300 hover:text-white hover:bg-white/10'
                  } flex items-center justify-center space-x-2`}
                >
                  <TabIcon className="h-4 w-4" />
                  <span className="font-medium">{tab.name}</span>
                  {tab.disabled && (
                    <span className="text-xs bg-gray-600 px-1.5 py-0.5 rounded-full">Soon</span>
                  )}
                  {activeTab === tab.id && (
                    <div className="absolute inset-0 bg-gradient-to-r from-white/20 to-transparent pointer-events-none" />
                  )}
                </button>
              );
            })}
          </div>
        </div>

        {(error || serviceError) && (
          <div className="mb-4 bg-red-900/20 backdrop-blur-sm border border-red-500/30 rounded-lg p-3 flex items-center space-x-2">
            <AlertTriangle className="h-4 w-4 text-red-400" />
            <span className="text-red-200 text-sm">{error || serviceError}</span>
            <button
              onClick={() => {
                setError(null);
                setServiceError(null);
              }}
              className="ml-auto text-red-400 hover:text-red-300 text-lg"
            >
              ×
            </button>
          </div>
        )}

        {/* Tab Content */}
        {activeTab === 'qsbp' && (
          <div className="space-y-4">
            {/* Compact QSBP Strategy Dashboard */}
            <div className="grid grid-cols-1 xl:grid-cols-4 gap-4">
              {/* Status Card - Spans 3 columns */}
              <div className="xl:col-span-3 bg-black/20 backdrop-blur-sm rounded-xl border border-white/10 overflow-hidden">
                <div className="p-4 border-b border-white/10">
                  <div className="flex items-center justify-between">
                    <div className="flex items-center space-x-3">
                      <div className="p-2 bg-gradient-to-r from-purple-500 to-pink-500 rounded-lg">
                        <Zap className="h-5 w-5 text-white" />
                      </div>
                      <div>
                        <h3 className="text-lg font-bold text-white">Equity Strategy</h3>
                        <p className="text-gray-400 text-sm">Advanced options scaling strategy</p>
                      </div>
                    </div>
                    
                    {/* Compact Toggle Switch - Same size as Ratio Strategy */}
                    <div className="flex items-center space-x-4">
                      <div className="flex items-center space-x-3">
                        <span className={`text-sm font-medium transition-colors duration-300 ${
                          getCurrentQSBPStatus()?.is_running ? 'text-green-400' : 'text-gray-400'
                        }`}>
                          {getCurrentQSBPStatus()?.is_running ? 'ACTIVE' : 'INACTIVE'}
                        </span>
                        
                        {/* Service Health Indicator */}
                        {!qsbpServiceHealth && (
                          <div className="flex items-center space-x-1 px-2 py-1 bg-red-900/30 rounded-md border border-red-500/30">
                            <div className="w-2 h-2 bg-red-400 rounded-full animate-pulse" />
                            <span className="text-red-400 text-xs font-medium">Service Down</span>
                          </div>
                        )}
                        
                        {/* Compact Futuristic Toggle Switch - Same size as Ratio Strategy */}
                        <div className="relative group">
                          <button
                            onClick={toggleQSBPStrategy}
                            disabled={actionLoading !== null}
                            className={`relative w-14 h-7 rounded-full transition-all duration-500 ease-in-out transform group-hover:scale-105 ${
                              getCurrentQSBPStatus()?.is_running
                                ? 'bg-gradient-to-r from-green-400 via-green-500 to-green-600 shadow-lg shadow-green-500/50' 
                                : 'bg-gradient-to-r from-gray-600 via-gray-700 to-gray-800 shadow-lg shadow-gray-700/30'
                            } disabled:opacity-50 border-2 border-white/20`}
                          >
                            {/* Glowing Background Effect */}
                            <div className={`absolute inset-0 rounded-full blur-sm transition-all duration-500 ${
                              getCurrentQSBPStatus()?.is_running
                                ? 'bg-gradient-to-r from-green-400 to-green-600 opacity-30 animate-pulse' 
                                : 'bg-gradient-to-r from-gray-600 to-gray-800 opacity-20'
                            }`} />
                            
                            {/* Toggle Ball */}
                            <div className={`absolute top-0.5 w-5 h-5 bg-gradient-to-br from-white to-gray-100 rounded-full transition-all duration-500 ease-in-out transform ${
                              getCurrentQSBPStatus()?.is_running ? 'translate-x-7 shadow-lg shadow-green-400/30' : 'translate-x-0.5 shadow-lg shadow-gray-400/30'
                            } border border-white/30`}>
                              {/* Inner Glow */}
                              <div className={`absolute inset-0.5 rounded-full transition-all duration-500 ${
                                getCurrentQSBPStatus()?.is_running
                                  ? 'bg-gradient-to-br from-green-100 to-green-200' 
                                  : 'bg-gradient-to-br from-gray-100 to-gray-200'
                              }`} />
                              
                              {/* Center Dot */}
                              <div className={`absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full transition-all duration-500 ${
                                getCurrentQSBPStatus()?.is_running
                                  ? 'bg-green-500 shadow-sm shadow-green-300' 
                                  : 'bg-gray-500 shadow-sm shadow-gray-300'
                              }`} />
                            </div>
                            
                            {/* Loading Spinner */}
                            {actionLoading !== null && (
                              <div className="absolute inset-0 flex items-center justify-center">
                                <div className="w-3 h-3 border-2 border-white/30 border-t-white rounded-full animate-spin" />
                              </div>
                            )}
                          </button>
                          
                          {/* Hover Glow Effect */}
                          <div className={`absolute inset-0 rounded-full transition-all duration-300 opacity-0 group-hover:opacity-100 ${
                            getCurrentQSBPStatus()?.is_running
                              ? 'bg-green-400/20 blur-md' 
                              : 'bg-blue-400/20 blur-md'
                          }`} />
                        </div>
                        
                        {/* Status Indicator */}
                        <div className="flex items-center space-x-2">
                          <div className={`w-2.5 h-2.5 rounded-full transition-all duration-300 ${
                            getCurrentQSBPStatus()?.is_running 
                              ? 'bg-green-400 shadow-lg shadow-green-400/50 animate-pulse' 
                              : 'bg-gray-400'
                          }`} />
                          <span className={`text-xs font-medium transition-colors duration-300 ${
                            getCurrentQSBPStatus()?.is_running ? 'text-green-400' : 'text-gray-400'
                          }`}>
                            {getCurrentQSBPStatus()?.is_running ? 'ON' : 'OFF'}
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                {/* Compact Metrics Grid */}
                <div className="p-4 grid grid-cols-2 lg:grid-cols-4 gap-3">
                  <div className="bg-white/5 rounded-lg p-3 border border-white/10">
                    <div className="flex items-center space-x-2">
                      <DollarSign className="h-4 w-4 text-green-400" />
                      <div>
                        <p className="text-gray-400 text-xs">Capital</p>
                        <p className="text-white font-bold text-sm">
                          {formatCurrency(getCurrentQSBPStatus()?.current_capital || qsbpConfig.capital)}
                        </p>
                      </div>
                    </div>
                  </div>
                  
                  <div className="bg-white/5 rounded-lg p-3 border border-white/10">
                    <div className="flex items-center space-x-2">
                      <TrendingUp className="h-4 w-4 text-blue-400" />
                      <div>
                        <p className="text-gray-400 text-xs">Daily P&L</p>
                        <p className={`font-bold text-sm ${
                          (getCurrentQSBPStatus()?.daily_pnl || 0) >= 0 ? 'text-green-400' : 'text-red-400'
                        }`}>
                          {formatCurrency(getCurrentQSBPStatus()?.daily_pnl || 0)}
                        </p>
                      </div>
                    </div>
                  </div>
                  
                  <div className="bg-white/5 rounded-lg p-3 border border-white/10">
                    <div className="flex items-center space-x-2">
                      <Activity className="h-4 w-4 text-purple-400" />
                      <div>
                        <p className="text-gray-400 text-xs">Positions</p>
                        <p className="text-white font-bold text-sm">{getCurrentQSBPStatus()?.positions_count || 0}</p>
                      </div>
                    </div>
                  </div>
                  
                  <div className="bg-white/5 rounded-lg p-3 border border-white/10">
                    <div className="flex items-center space-x-2">
                      <BarChart3 className="h-4 w-4 text-orange-400" />
                      <div>
                        <p className="text-gray-400 text-xs">Total Trades</p>
                        <p className="text-white font-bold text-sm">{getCurrentQSBPStatus()?.total_trades || 0}</p>
                      </div>
                    </div>
                  </div>
                </div>

                {/* Compact Exposure Metrics */}
                <div className="p-4 border-t border-white/10">
                  <h4 className="text-sm font-semibold text-white mb-3">Exposure Analysis</h4>
                  <div className="grid grid-cols-3 gap-3">
                    <div className="text-center">
                      <p className="text-gray-400 text-xs">Long Exposure</p>
                      <p className="text-lg font-bold text-green-400">
                        {formatCurrency(getCurrentQSBPStatus()?.long_exposure || 0)}
                      </p>
                    </div>
                    <div className="text-center">
                      <p className="text-gray-400 text-xs">Short Exposure</p>
                      <p className="text-lg font-bold text-red-400">
                        {formatCurrency(getCurrentQSBPStatus()?.short_exposure || 0)}
                      </p>
                    </div>
                    <div className="text-center">
                      <p className="text-gray-400 text-xs">Total Exposure</p>
                      <p className="text-lg font-bold text-blue-400">
                        {formatCurrency(getCurrentQSBPStatus()?.total_exposure || 0)}
                      </p>
                    </div>
                  </div>
                </div>
              </div>

              {/* Compact Configuration Panel */}
