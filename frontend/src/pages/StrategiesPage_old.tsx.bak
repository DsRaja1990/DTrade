                    <div className="lg:col-span-2">
                      <label className="block text-xs text-gray-400 mb-1">Access Token</label>                        <input
                          type="password"
                          value={indexScalpingConfig.dhan_access_token || ''}
                          onChange={(e) => setIndexScalpingConfig(prev => ({ ...prev, dhan_access_token: e.target.value }))}
                          className="w-full bg-white/10 border border-white/20 rounded-md px-2 py-1 text-white text-xs futuristic-input"
                          placeholder="Dhan Access Token"
                        />
                    </div>
                  </>
                )}
              </div>
            </div>

            {/* Compact Strategy Info */}
            <div className="bg-gradient-to-r from-purple-500/10 to-pink-500/10 backdrop-blur-sm rounded-lg border border-purple-500/30 p-3">
              <div className="grid grid-cols-1 lg:grid-cols-2 gap-3">
                <div>
                  <h4 className="text-xs font-semibold text-purple-300 mb-2 flex items-center">
                    <Brain className="h-3 w-3 mr-1" />
                    Features
                  </h4>
                  <div className="space-y-1 text-xs text-gray-400">
                    <div className="flex items-center space-x-2">
                      <div className="w-1 h-1 bg-cyan-400 rounded-full"></div>
                      <span>90s Max Duration</span>
                    </div>
                    <div className="flex items-center space-x-2">
                      <div className="w-1 h-1 bg-blue-400 rounded-full"></div>
                      <span>Triple Signal Confirmation</span>
                    </div>
                    <div className="flex items-center space-x-2">
                      <div className="w-1 h-1 bg-green-400 rounded-full"></div>
                      <span>Dynamic VIX Scaling</span>
                    </div>
                  </div>
                </div>
                <div>
                  <h4 className="text-xs font-semibold text-pink-300 mb-2 flex items-center">
                    <AlertTriangle className="h-3 w-3 mr-1" />
                    Risk Controls
                  </h4>
                  <div className="space-y-1 text-xs text-gray-400">
                    <div className="flex items-center space-x-2">
                      <div className="w-1 h-1 bg-green-400 rounded-full"></div>
                      <span>0.3% Profit Target</span>
                    </div>
                    <div className="flex items-center space-x-2">
                      <div className="w-1 h-1 bg-red-400 rounded-full"></div>
                      <span>0.5% Max Loss</span>
                    </div>
                    <div className="flex items-center space-x-2">
                      <div className="w-1 h-1 bg-yellow-400 rounded-full"></div>
                      <span>Real-time Monitoring</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        )}

        {/* Equity HV Strategy Tab */}
        {activeTab === 'equity-hv' && (
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
            {/* Service Health Card */}
            <div className="bg-black/20 backdrop-blur-sm rounded-xl border border-white/10 p-6">
              <div className="flex items-center justify-between mb-4">
                <h3 className="text-lg font-semibold text-white">Service Health</h3>
                <div className={`px-3 py-1 rounded-full text-sm font-medium ${
                  equityHVServiceHealth 
                    ? 'bg-green-500/20 text-green-400 border border-green-500/30' 
                    : 'bg-red-500/20 text-red-400 border border-red-500/30'
                }`}>
                  {equityHVServiceHealth ? 'Online' : 'Offline'}
                </div>
              </div>
              
              <div className="space-y-2">
                <p className="text-sm text-gray-300">
                  <span className="font-medium text-white">Port:</span> 8003
                </p>
                <p className="text-sm text-gray-300">
                  <span className="font-medium text-white">Service:</span> Equity HV Trading Engine
                </p>
                <p className="text-sm text-gray-300">
                  <span className="font-medium text-white">Status:</span> {equityHVServiceHealth ? 'Operational' : 'Unavailable'}
                </p>
              </div>
            </div>

            {/* Paper Trading Control Card */}
            <div className="bg-black/20 backdrop-blur-sm rounded-xl border border-white/10 p-6">
              <div className="flex items-center justify-between mb-4">
                <h3 className="text-lg font-semibold text-white">Paper Trading</h3>
                <div className={`px-3 py-1 rounded-full text-sm font-medium ${
                  equityHVStatus?.is_running 
                    ? 'bg-green-500/20 text-green-400 border border-green-500/30' 
                    : 'bg-gray-500/20 text-gray-400 border border-gray-500/30'
                }`}>
                  {equityHVStatus?.is_running ? 'Running' : 'Stopped'}
                </div>
              </div>
              
              <div className="space-y-4">
                <button
                  onClick={() => toggleEquityHVStrategy('paper')}
                  disabled={loading}
                  className={`w-full px-4 py-3 rounded-lg font-medium transition-colors ${
                    equityHVStatus?.is_running
                      ? 'bg-red-600 hover:bg-red-700 text-white'
                      : 'bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white'
                  } disabled:opacity-50 disabled:cursor-not-allowed`}
                >
                  {loading ? 'Processing...' : equityHVStatus?.is_running ? 'Stop Paper Trading' : 'Start Paper Trading'}
                </button>
                
                {equityHVStatus && (
                  <div className="grid grid-cols-2 gap-4 text-sm">
                    <div>
                      <p className="text-gray-400">Total Trades:</p>
                      <p className="font-semibold text-white">{equityHVStatus.total_trades || 0}</p>
                    </div>
                    <div>
                      <p className="text-gray-400">Daily PnL:</p>
                      <p className={`font-semibold ${
                        (equityHVStatus.daily_pnl || 0) >= 0 ? 'text-green-400' : 'text-red-400'
                      }`}>
                        ₹{equityHVStatus.daily_pnl?.toFixed(2) || '0.00'}
                      </p>
                    </div>
                  </div>
                )}
              </div>
            </div>

            {/* Live Trading Control Card */}
            <div className="bg-black/20 backdrop-blur-sm rounded-xl border border-white/10 p-6">
              <div className="flex items-center justify-between mb-4">
                <h3 className="text-lg font-semibold text-white">Live Trading</h3>
                <div className={`px-3 py-1 rounded-full text-sm font-medium ${
                  equityHVLiveStatus?.is_running 
                    ? 'bg-green-500/20 text-green-400 border border-green-500/30' 
                    : 'bg-gray-500/20 text-gray-400 border border-gray-500/30'
                }`}>
                  {equityHVLiveStatus?.is_running ? 'Active' : 'Inactive'}
                </div>
              </div>
              
              <div className="space-y-4">
                <div className="bg-yellow-500/10 border border-yellow-500/30 rounded-lg p-3">
                  <p className="text-sm text-yellow-400">
                    ⚠️ Live trading uses real money. Please ensure you understand the risks.
                  </p>
                </div>
                
                <button
                  onClick={() => toggleEquityHVStrategy('live')}
                  disabled={loading}
                  className={`w-full px-4 py-3 rounded-lg font-medium transition-colors ${
                    equityHVLiveStatus?.is_running
                      ? 'bg-red-600 hover:bg-red-700 text-white'
                      : 'bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700 text-white'
                  } disabled:opacity-50 disabled:cursor-not-allowed`}
                >
                  {loading ? 'Processing...' : equityHVLiveStatus?.is_running ? 'Stop Live Trading' : 'Start Live Trading'}
                </button>
                
                {equityHVLiveStatus && (
                  <div className="grid grid-cols-2 gap-4 text-sm">
                    <div>
                      <p className="text-gray-400">Live Trades:</p>
                      <p className="font-semibold text-white">{equityHVLiveStatus.total_trades || 0}</p>
                    </div>
                    <div>
                      <p className="text-gray-400">Live PnL:</p>
                      <p className={`font-semibold ${
                        (equityHVLiveStatus.daily_pnl || 0) >= 0 ? 'text-green-400' : 'text-red-400'
                      }`}>
                        ₹{equityHVLiveStatus.daily_pnl?.toFixed(2) || '0.00'}
                      </p>
                    </div>
                  </div>
                )}
              </div>
            </div>

            {/* Strategy Configuration Card */}
            <div className="bg-black/20 backdrop-blur-sm rounded-xl border border-white/10 p-6">
              <h3 className="text-lg font-semibold text-white mb-4">Strategy Configuration</h3>
              
              <div className="space-y-4">
                <div className="grid grid-cols-2 gap-4 text-sm">
                  <div>
                    <p className="text-gray-400">Strategy:</p>
                    <p className="font-semibold text-white">Equity Hyper-Volatility</p>
                  </div>
                  <div>
                    <p className="text-gray-400">Market:</p>
                    <p className="font-semibold text-white">NSE Equity</p>
                  </div>
                  <div>
                    <p className="text-gray-400">Risk Level:</p>
                    <p className="font-semibold text-orange-400">High</p>
                  </div>
                  <div>
                    <p className="text-gray-400">Target Stocks:</p>
                    <p className="font-semibold text-white">10 Elite Stocks</p>
                  </div>
                </div>
                
                <div className="border-t border-white/10 pt-4">
                  <p className="text-sm text-gray-300 mb-2">
                    <span className="font-medium text-white">Description:</span> Advanced momentum-based strategy targeting high-volatility opportunities in elite equity stocks with quantum adaptive algorithms.
                  </p>
                  <p className="text-sm text-gray-300">
                    <span className="font-medium text-white">Key Features:</span> Real-time volatility analysis, adaptive position sizing, quantum momentum indicators, enhanced risk management.
                  </p>
                </div>
              </div>
            </div>
          </div>
        )}

      </div>
    </div>
  );
};

export default StrategiesPage;
