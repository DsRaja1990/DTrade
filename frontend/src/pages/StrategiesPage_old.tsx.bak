                      (indexScalpingStatus?.daily_pnl || 0) >= 0 ? 'text-green-400' : 'text-red-400'
                    }`}>
                      ₹{Math.abs(indexScalpingStatus?.daily_pnl || 0).toLocaleString()}
                    </div>
                    <div className="text-xs text-gray-400">P&L</div>
