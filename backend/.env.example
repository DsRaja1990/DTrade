# DTrade Environment Configuration
# Copy this file to .env in the backend directory and update the values

# Security
SECRET_KEY=your_secret_key_here_replace_with_actual_secure_key
JWT_SECRET=your_jwt_secret_here_replace_with_actual_secure_key

# Database
DATABASE_URL=sqlite:///./dtrade.db

# Redis (for caching and websockets)
REDIS_URL=redis://localhost:6379

# DhanHQ API (for live trading - optional for demo mode)
DHAN_CLIENT_ID=your_dhan_client_id_here
DHAN_ACCESS_TOKEN=your_dhan_access_token_here

# Optional: Other settings
DEBUG=True
LOG_LEVEL=INFO
ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
