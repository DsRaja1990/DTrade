# ==================== SIGNALS ENDPOINTS ====================
@app.get("/api/signals/latest")
async def get_signals_latest(limit: int = 20):
    """Get latest signals from all services"""
    import aiohttp
    
    all_signals = []
    service_endpoints = [
        ("http://localhost:4080/api/signals/latest", "Gemini"),
        ("http://localhost:4002/api/signals", "AI Scalping"),
        ("http://localhost:4003/api/signals", "AI Hedger"),
        ("http://localhost:5080/api/signals", "Elite Equity"),
    ]
    
    async with aiohttp.ClientSession() as session:
        for url, source in service_endpoints:
            try:
                async with session.get(url, timeout=aiohttp.ClientTimeout(total=3)) as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        signals = data.get("signals", [])
                        for s in signals:
                            s["source"] = source
                        all_signals.extend(signals)
            except Exception as e:
                logger.debug(f"Could not fetch signals from {source}: {e}")
    
    # Sort by timestamp and limit
    all_signals.sort(key=lambda x: x.get("timestamp", ""), reverse=True)
    
    return {
        "status": "success",
        "signals": all_signals[:limit],
        "count": len(all_signals[:limit]),
        "timestamp": datetime.now().isoformat()
    }

