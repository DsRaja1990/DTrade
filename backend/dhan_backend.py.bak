# ==================== SERVICES STATUS (TRADING STRATEGIES) ====================
SERVICE_PORTS = {
    "AIScalpingService": 4002,
    "AIOptionsHedger": 4003,
    "GeminiTradeService": 4080,
    "EliteEquityHVService": 5080
}

@app.get("/api/services/status")
async def get_services_status():
    """Get status of all trading services"""
    services = []
    
    async with httpx.AsyncClient(timeout=5.0) as client:
        for name, port in SERVICE_PORTS.items():
            try:
                response = await client.get(f"http://localhost:{port}/health")
                status = "running" if response.status_code == 200 else "error"
            except:
                status = "stopped"
            
            services.append({
                "name": name,
                "port": port,
                "status": status,
                "last_check": datetime.now().isoformat()
            })
    
    return {"status": "success", "services": services}

# ==================== WEBSOCKET FOR LIVE UPDATES ====================
@app.websocket("/ws")
async def websocket_endpoint(websocket: WebSocket):
    await websocket.accept()
    active_connections.append(websocket)
    logger.info(f"✅ WebSocket connected. Total connections: {len(active_connections)}")
    
    try:
        while True:
            # Keep connection alive and listen for messages
            message = await websocket.receive_text()
            
            try:
                data = json.loads(message) if message.startswith('{') else {"type": message}
            except:
                data = {"type": message}
            
            message_type = data.get("type", message)
            
            # Handle heartbeat ping/pong
            if message_type == "ping":
                await websocket.send_json({"type": "pong", "timestamp": datetime.now().timestamp()})
            elif message_type == "positions":
                positions = await get_positions()
                await websocket.send_json({"type": "positions", "data": positions})
            elif message_type == "orders":
                orders = await get_orders()
                await websocket.send_json({"type": "orders", "data": orders})
            elif message_type == "portfolio":
                portfolio = await get_portfolio()
                await websocket.send_json({"type": "portfolio", "data": portfolio})
            elif message_type == "funds":
                funds = await get_fund_limits()
                await websocket.send_json({"type": "funds", "data": funds})
            else:
                logger.debug(f"Unknown WebSocket message type: {message_type}")
                
    except WebSocketDisconnect:
        active_connections.remove(websocket)
        logger.info(f"🔌 WebSocket disconnected. Total connections: {len(active_connections)}")

@app.websocket("/ws/live-data")
async def websocket_live_data(websocket: WebSocket):
    """WebSocket for live market data updates"""
    await websocket.accept()
    active_connections.append(websocket)
    logger.info(f"Live data WebSocket connected. Total: {len(active_connections)}")
    
    try:
        while True:
            data = await websocket.receive_text()
            if data == "ping":
                await websocket.send_text("pong")
    except WebSocketDisconnect:
        active_connections.remove(websocket)
        logger.info(f"Live data WebSocket disconnected. Total: {len(active_connections)}")

async def broadcast_update(message: Dict):
    """Broadcast update to all connected WebSocket clients"""
    for connection in active_connections:
        try:
            await connection.send_json(message)
        except:
            pass

