# ==================== TOKEN UPDATE ENDPOINT (HOT-RELOAD) ====================
@app.post("/update-token")
async def update_token(request: TokenUpdateRequest):
    """
    Update Dhan API token at runtime WITHOUT requiring service restart.
    This enables seamless daily token updates.
    """
    try:
        old_token_prefix = dhan_config.access_token[:20] if dhan_config.access_token else "None"
        
        # Update in-memory config
        dhan_config.access_token = request.access_token
        if request.client_id:
            dhan_config.client_id = request.client_id
        
        logger.info(f"Token updated: {old_token_prefix}... -> {request.access_token[:20]}...")
        
        # Verify token works by making a test call
        try:
            test_result = await dhan_api_request("GET", "/fundlimit")
            token_valid = "error" not in test_result
        except:
            token_valid = False
        
        return {
            "success": True,
            "message": "Token updated successfully in memory",
            "token_valid": token_valid,
            "client_id": dhan_config.client_id,
            "restart_required": False
        }
    except Exception as e:
        logger.error(f"Token update failed: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@app.get("/token-status")
async def token_status():
    """Check current token status"""
    token_preview = f"{dhan_config.access_token[:20]}...{dhan_config.access_token[-10:]}" if dhan_config.access_token else "Not set"
    
    # Test if token is valid
    try:
        result = await dhan_api_request("GET", "/fundlimit")
        is_valid = "error" not in result and "status_code" not in result
    except:
        is_valid = False
    
    return {
        "client_id": dhan_config.client_id,
        "token_preview": token_preview,
        "token_length": len(dhan_config.access_token) if dhan_config.access_token else 0,
        "is_valid": is_valid,
        "timestamp": datetime.now().isoformat()
    }

# ==================== PORTFOLIO ENDPOINTS ====================
@app.get("/api/portfolio")
async def get_portfolio():
    """Get complete portfolio including holdings and positions"""
    try:
        holdings = await dhan_api_request("GET", "/holdings")
        positions = await dhan_api_request("GET", "/positions")
        
        total_investment = 0
        total_current_value = 0
        total_pnl = 0
        
        if isinstance(holdings, list):
            for holding in holdings:
                buy_avg = holding.get("avgCostPrice", 0)
                qty = holding.get("totalQty", 0)
                ltp = holding.get("lastTradedPrice", buy_avg)
                investment = buy_avg * qty
                current = ltp * qty
                total_investment += investment
                total_current_value += current
                total_pnl += current - investment
        
        return {
            "status": "success",
            "timestamp": datetime.now().isoformat(),
            "summary": {
                "total_investment": round(total_investment, 2),
                "current_value": round(total_current_value, 2),
                "total_pnl": round(total_pnl, 2),
                "pnl_percentage": round((total_pnl / total_investment * 100), 2) if total_investment > 0 else 0
            },
            "holdings": holdings if isinstance(holdings, list) else [],
            "positions": positions if isinstance(positions, list) else []
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error fetching portfolio: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@app.get("/api/holdings")
async def get_holdings():
    """Get all holdings from Dhan"""
    try:
        holdings = await dhan_api_request("GET", "/holdings")
        
        if isinstance(holdings, list):
            formatted_holdings = []
            for h in holdings:
                formatted_holdings.append({
                    "symbol": h.get("tradingSymbol", ""),
                    "exchange": h.get("exchange", "NSE"),
                    "quantity": h.get("totalQty", 0),
                    "avg_price": h.get("avgCostPrice", 0),
                    "ltp": h.get("lastTradedPrice", 0),
                    "current_value": h.get("totalQty", 0) * h.get("lastTradedPrice", 0),
                    "pnl": (h.get("lastTradedPrice", 0) - h.get("avgCostPrice", 0)) * h.get("totalQty", 0),
                    "security_id": h.get("securityId", ""),
                    "isin": h.get("isin", "")
                })
            return {"status": "success", "data": formatted_holdings, "count": len(formatted_holdings)}
        
        return {"status": "success", "data": holdings, "count": 0}
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error fetching holdings: {e}")
        raise HTTPException(status_code=500, detail=str(e))

