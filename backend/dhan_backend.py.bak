# ==================== DHAN API HELPER ====================
def get_dhan_headers() -> Dict[str, str]:
    """Get headers for Dhan API requests - uses mutable config"""
    return {
        "Content-Type": "application/json",
        "Accept": "application/json",
        "access-token": dhan_config.access_token,
        "client-id": dhan_config.client_id  # Required for market feed API
    }

async def dhan_api_request(method: str, endpoint: str, data: Optional[Dict] = None) -> Dict:
    """Make a request to Dhan API"""
    url = f"{DHAN_API_BASE}{endpoint}"
    headers = get_dhan_headers()
    
    try:
        async with httpx.AsyncClient(timeout=30.0) as client:
            if method.upper() == "GET":
                response = await client.get(url, headers=headers)
            elif method.upper() == "POST":
                response = await client.post(url, headers=headers, json=data)
            elif method.upper() == "PUT":
                response = await client.put(url, headers=headers, json=data)
            elif method.upper() == "DELETE":
                response = await client.delete(url, headers=headers)
            else:
                raise ValueError(f"Unsupported HTTP method: {method}")
            
            if response.status_code == 200:
                return response.json()
            elif response.status_code == 401:
                raise HTTPException(status_code=401, detail="Dhan API authentication failed. Token may be expired.")
            else:
                logger.error(f"Dhan API error: {response.status_code} - {response.text}")
                return {"error": response.text, "status_code": response.status_code}
    except httpx.RequestError as e:
        logger.error(f"Dhan API request error: {e}")
        raise HTTPException(status_code=503, detail=f"Dhan API unavailable: {str(e)}")

