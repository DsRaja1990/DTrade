@app.get("/api/signals/latest")
async def get_latest_signals(limit: int = 10):
    """Get latest trading signals from services"""
    signals = []
    
    # Try to fetch from trading services
    async with httpx.AsyncClient(timeout=5.0) as client:
        for name, port in SERVICE_PORTS.items():
            try:
                response = await client.get(f"http://localhost:{port}/api/signals")
                if response.status_code == 200:
                    data = response.json()
                    if isinstance(data, list):
                        signals.extend(data[:limit])
                    elif "signals" in data:
                        signals.extend(data["signals"][:limit])
            except:
                pass
    
    return {"signals": signals[:limit]}

