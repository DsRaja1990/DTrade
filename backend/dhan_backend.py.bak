@app.get("/api/market/stats")
async def get_market_stats():
    """Get market statistics with actual market hours check"""
    from datetime import time as dt_time
    
    now = datetime.now()
    current_time = now.time()
    
    # NSE market hours: 9:15 AM - 3:30 PM, Monday-Friday
    market_open_time = dt_time(9, 15)
    market_close_time = dt_time(15, 30)
    is_weekday = now.weekday() < 5  # Monday=0, Friday=4
    
    is_market_open = is_weekday and market_open_time <= current_time <= market_close_time
    
    # Determine session
    if not is_weekday:
        session = "weekend"
    elif current_time < market_open_time:
        session = "pre-market"
    elif current_time > market_close_time:
        session = "post-market"
    else:
        session = "open"
    
    return {
        "market_open": is_market_open,
        "session": session,
        "current_time": current_time.isoformat(),
        "market_hours": "09:15-15:30",
        "timestamp": now.isoformat()
    }

# ==================== REAL-TIME MARKET QUOTE ENDPOINTS (FOR SIGNAL ENGINE) ====================
# Dhan Security IDs for indices
INDEX_SECURITY_IDS = {
    "NIFTY": {"security_id": "13", "exchange": "NSE_FNO", "exchange_segment": "IDX_I"},
    "BANKNIFTY": {"security_id": "25", "exchange": "NSE_FNO", "exchange_segment": "IDX_I"},
    "SENSEX": {"security_id": "51", "exchange": "BSE_FNO", "exchange_segment": "IDX_I"},
    "FINNIFTY": {"security_id": "27", "exchange": "NSE_FNO", "exchange_segment": "IDX_I"},
    "MIDCPNIFTY": {"security_id": "442", "exchange": "NSE_FNO", "exchange_segment": "IDX_I"},
}

@app.get("/api/market/quote/{instrument}")
async def get_market_quote(instrument: str):
    """
    Get real-time market quote for an index instrument (NIFTY, BANKNIFTY, SENSEX, etc.)
    Used by Signal Engine for real-time market data.
    """
    instrument_upper = instrument.upper()
    
    if instrument_upper not in INDEX_SECURITY_IDS:
        raise HTTPException(
            status_code=400, 
            detail=f"Unknown instrument: {instrument}. Available: {list(INDEX_SECURITY_IDS.keys())}"
        )
    
    config = INDEX_SECURITY_IDS[instrument_upper]
    
    try:
        # Dhan Market Quote API - Use IDX_I for indices
        url = f"{DHAN_API_BASE}/marketfeed/ltp"
        headers = get_dhan_headers()
        
        # Request payload for Dhan LTP API - Use IDX_I segment for indices
        payload = {
            "IDX_I": [int(config["security_id"])]  # Correct segment for index data
        }
        
        async with httpx.AsyncClient(timeout=10.0) as client:
            response = await client.post(url, headers=headers, json=payload)
            
            if response.status_code == 200:
                data = response.json()
                logger.info(f"Dhan LTP Response for {instrument}: {data}")
                
                # Parse Dhan response - IDX_I format
                ltp = 0.0
                if "data" in data and "IDX_I" in data["data"]:
                    idx_data = data["data"]["IDX_I"]
                    if config["security_id"] in idx_data:
                        ltp = float(idx_data[config["security_id"]].get("last_price", 0))
                
                # If no data from Dhan, try alternative endpoint
                if ltp == 0:
                    # Try getting from indices endpoint
                    ltp = await _fetch_index_ltp_alternative(instrument_upper)
                
                return {
                    "instrument": instrument_upper,
                    "security_id": config["security_id"],
                    "exchange": config["exchange"],
                    "ltp": ltp,
                    "open": ltp * 0.998,  # Approximate from LTP
                    "high": ltp * 1.002,
                    "low": ltp * 0.997,
                    "close": ltp,
                    "change": 0,
                    "change_percent": 0,
                    "volume": 0,
                    "timestamp": datetime.now().isoformat(),
                    "source": "dhan_api"
                }
            else:
                logger.error(f"Dhan API error: {response.status_code} - {response.text}")
                # Return fallback data
                return await _get_fallback_quote(instrument_upper)
                
    except Exception as e:
        logger.error(f"Error fetching market quote for {instrument}: {e}")
        return await _get_fallback_quote(instrument_upper)


async def _fetch_index_ltp_alternative(instrument: str) -> float:
    """Alternative method to fetch index LTP using different Dhan endpoint"""
    try:
        # Try using the intraday chart data API
        config = INDEX_SECURITY_IDS.get(instrument, {})
        if not config:
            return 0.0
            
        url = f"{DHAN_API_BASE}/charts/intraday"
        headers = get_dhan_headers()
        
        from_date = datetime.now().strftime("%Y-%m-%d")
        payload = {
            "securityId": config["security_id"],
            "exchangeSegment": config["exchange_segment"],
            "instrument": "INDEX",
            "fromDate": from_date,
            "toDate": from_date
        }
        
        async with httpx.AsyncClient(timeout=10.0) as client:
            response = await client.post(url, headers=headers, json=payload)
            
            if response.status_code == 200:
                data = response.json()
                if "close" in data and data["close"]:
                    return float(data["close"][-1])  # Last close price
        return 0.0
    except Exception as e:
        logger.error(f"Alternative LTP fetch failed: {e}")
        return 0.0


async def _get_fallback_quote(instrument: str) -> dict:
    """Get fallback quote when Dhan API is unavailable"""
    # Typical market values for fallback
    fallback_prices = {
        "NIFTY": 24500.0,
        "BANKNIFTY": 52500.0,
        "SENSEX": 81000.0,
        "FINNIFTY": 23800.0,
        "MIDCPNIFTY": 12500.0,
    }
    
    price = fallback_prices.get(instrument, 20000.0)
    
    return {
        "instrument": instrument,
        "security_id": INDEX_SECURITY_IDS.get(instrument, {}).get("security_id", "0"),
        "exchange": INDEX_SECURITY_IDS.get(instrument, {}).get("exchange", "NSE"),
        "ltp": price,
        "open": price * 0.998,
        "high": price * 1.002,
        "low": price * 0.997,
        "close": price,
        "change": 0,
        "change_percent": 0,
        "volume": 0,
        "timestamp": datetime.now().isoformat(),
        "source": "fallback",
        "warning": "Using fallback data - Dhan API unavailable"
    }


@app.get("/api/market/intraday/{instrument}")
async def get_intraday_data(instrument: str, interval: str = "5"):
    """
    Get intraday OHLC data for an instrument.
    interval: 1, 5, 15, 25, 60 minutes
    """
    instrument_upper = instrument.upper()
    
    if instrument_upper not in INDEX_SECURITY_IDS:
        raise HTTPException(
            status_code=400,
            detail=f"Unknown instrument: {instrument}. Available: {list(INDEX_SECURITY_IDS.keys())}"
        )
    
    config = INDEX_SECURITY_IDS[instrument_upper]
    
    try:
        url = f"{DHAN_API_BASE}/charts/intraday"
        headers = get_dhan_headers()
        
        from_date = datetime.now().strftime("%Y-%m-%d")
        payload = {
            "securityId": config["security_id"],
            "exchangeSegment": config["exchange_segment"],
            "instrument": "INDEX",
            "interval": interval,
            "fromDate": from_date,
            "toDate": from_date
        }
        
        async with httpx.AsyncClient(timeout=15.0) as client:
            response = await client.post(url, headers=headers, json=payload)
            
            if response.status_code == 200:
                data = response.json()
                
                # Parse Dhan intraday response
                candles = []
                if "open" in data and "high" in data and "low" in data and "close" in data:
                    timestamps = data.get("timestamp", [])
                    opens = data.get("open", [])
                    highs = data.get("high", [])
                    lows = data.get("low", [])
                    closes = data.get("close", [])
                    volumes = data.get("volume", [])
                    
                    for i in range(len(opens)):
                        candles.append({
                            "timestamp": timestamps[i] if i < len(timestamps) else None,
                            "open": opens[i],
                            "high": highs[i],
                            "low": lows[i],
                            "close": closes[i],
                            "volume": volumes[i] if i < len(volumes) else 0
                        })
                
                return {
                    "instrument": instrument_upper,
                    "interval": interval,
                    "candles": candles,
                    "count": len(candles),
                    "timestamp": datetime.now().isoformat(),
                    "source": "dhan_api"
                }
            else:
                logger.error(f"Dhan intraday API error: {response.status_code}")
                return {
                    "instrument": instrument_upper,
                    "interval": interval,
                    "candles": [],
                    "count": 0,
                    "timestamp": datetime.now().isoformat(),
                    "source": "error",
                    "error": response.text
                }
                
    except Exception as e:
        logger.error(f"Error fetching intraday data: {e}")
        return {
            "instrument": instrument_upper,
            "interval": interval,
            "candles": [],
            "count": 0,
            "timestamp": datetime.now().isoformat(),
            "source": "error",
            "error": str(e)
        }


# ==================== MAIN ENTRY ====================
def main():
    """Run the DhanHQ backend server"""
    print("=" * 60)
    print("🚀 DTrade DhanHQ Backend Service")
    print("=" * 60)
    print(f"📊 Dhan Client ID: {dhan_config.client_id}")
    print(f"🌐 Server: http://localhost:8000")
    print("=" * 60)
    print("📋 API Endpoints:")
    print("   GET  /health             - Health check")
    print("   GET  /api/portfolio      - Complete portfolio")
    print("   GET  /api/holdings       - Holdings")
    print("   GET  /api/positions      - Open positions")
    print("   GET  /api/orders         - Today's orders")
    print("   POST /api/orders         - Place order")
    print("   PUT  /api/orders/{id}    - Modify order")
    print("   DEL  /api/orders/{id}    - Cancel order")
    print("   GET  /api/funds          - Fund limits")
    print("   GET  /api/fundlimit      - Fund limits (alias)")
    print("   GET  /api/trades         - Today's trades")
    print("   GET  /api/market/quote/{instrument} - Real-time quote")
    print("   GET  /api/market/intraday/{instrument} - Intraday OHLC")
    print("   GET  /api/services/status - Trading services status")
    print("   WS   /ws                 - WebSocket for live updates")
    print("=" * 60)
    print("⚡ Press Ctrl+C to stop")
    print()
    
    try:
        uvicorn.run(
            "dhan_backend:app",
            host="0.0.0.0",
            port=8000,
            reload=False,
            log_level="info"
        )
    except KeyboardInterrupt:
        print("\n🛑 Server stopped")
    except Exception as e:
        print(f"❌ Server error: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
