# --- Helper Functions ---

def call_gemini_tier_1_2(system_prompt, user_content):
    """Call Gemini for Tier 1 and Tier 2 using dedicated API key"""
    try:
        response = tier_1_2_client.models.generate_content(
            model="gemini-2.0-flash-exp",  # Using latest Flash model
            contents=user_content,
            config=types.GenerateContentConfig(
                system_instruction=system_prompt,
                response_mime_type="application/json",
                temperature=0.3
            )
        )
        return json.loads(response.text)
    except Exception as e:
        logger.error(f"Error calling Gemini Tier 1/2: {e}")
        return None

def call_gemini_tier_3(system_prompt, user_content):
    """Call Gemini for Tier 3 using separate dedicated API key (Pro model)"""
    try:
        response = tier_3_client.models.generate_content(
            model="gemini-1.5-pro",  # Using Pro model for risk analysis
            contents=user_content,
            config=types.GenerateContentConfig(
                system_instruction=system_prompt,
                response_mime_type="application/json",
                temperature=0.2  # More conservative for risk
            )
        )
        return json.loads(response.text)
    except Exception as e:
        logger.error(f"Error calling Gemini Tier 3: {e}")
        return None

async def get_tier_1_analysis(force_refresh=False):
    """
    Tier 1: Stock Screener
    Cache for 1 minute to avoid redundant calls
    """
    cache_key = "tier_1_analysis"
    current_time = datetime.now()
    
    # Check cache
    if not force_refresh and cache_key in tier_1_cache:
        cached_data, cached_time = tier_1_cache[cache_key]
        if (current_time - cached_time).seconds < 60:  # 1 minute cache
            logger.info("Returning cached Tier 1 analysis")
            return cached_data
    
    try:
        # Fetch data
        constituents_data = await dhan_client.get_nifty_constituents_data_enhanced()
        
        if not constituents_data:
            logger.error("No constituent data available")
            return None
        
        # Call Tier 1 AI
        tier1_payload = json.dumps(constituents_data)
        tier1_response = call_gemini_tier_1_2(
            system_prompt=TIER_1_ENHANCED_PROMPT,
            user_content=f"Analyze these 50 Nifty stocks: {tier1_payload}"
        )
        
        if tier1_response:
            # Cache the result
            tier_1_cache[cache_key] = (tier1_response, current_time)
            logger.info(f"Tier 1 Analysis: {tier1_response.get('weighted_bias', 'N/A')} - Score: {tier1_response.get('strength_score', 0)}")
        
        return tier1_response
    
    except Exception as e:
        logger.error(f"Error in Tier 1 analysis: {e}")
        return None

async def get_tier_2_proposal(tier1_analysis):
    """
    Tier 2: Strategy Engine
    Cache for 5 minutes OR when called explicitly
    """
    cache_key = "tier_2_proposal"
    current_time = datetime.now()
    
    # Check cache
    if cache_key in tier_2_cache:
        cached_data, cached_time = tier_2_cache[cache_key]
        if (current_time - cached_time).seconds < 300:  # 5 minute cache
            logger.info("Returning cached Tier 2 proposal")
            return cached_data
    
    try:
        # Fetch additional data
        nifty_data = dhan_client.get_nifty_index_data()
        option_chain_data = dhan_client.get_option_chain_data_enhanced()
        
        tier2_input = {
            "tier1_analysis": tier1_analysis,
            "nifty_spot_price": n ifty_data.get("current_price"),
            "nifty_rsi": nifty_data.get("rsi"),
            "option_chain": option_chain_data
        }
        
        # Call Tier 2 AI
        tier2_response = call_gemini_tier_1_2(
            system_prompt=TIER_2_ENHANCED_PROMPT,
            user_content=f"Formulate trade setup: {json.dumps(tier2_input)}"
        )
        
        if tier2_response:
            # Cache the result
            tier_2_cache[cache_key] = (tier2_response, current_time)
            logger.info(f"Tier 2 Proposal: {tier2_response.get('trade_signal', 'N/A')} - Confidence: {tier2_response.get('confidence', 'N/A')}")
        
        return tier2_response
    
    except Exception as e:
        logger.error(f"Error in Tier 2 analysis: {e}")
        return None

