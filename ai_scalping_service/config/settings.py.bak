@dataclass 
class IndexConfig:
    """Index-specific configuration"""
    symbol: str
    exchange: str
    lot_size: int
    total_lots: int
    max_exposure_percent: float = 60.0
    initial_allocation_percent: float = 20.0
    
    @property
    def initial_lots(self) -> int:
        """Calculate initial position size"""
        return int(self.total_lots * self.initial_allocation_percent / 100)
    
    @property
    def max_lots(self) -> int:
        """Calculate maximum position size"""
        return int(self.total_lots * self.max_exposure_percent / 100)

@dataclass
class ScalpingParameters:
    """Core scalping algorithm parameters"""
    # Entry Signals
    ema_fast_period: int = 5
    ema_slow_period: int = 15
    volume_surge_multiplier: float = 1.5
    pcr_oversold_threshold: float = 0.85
    pcr_overbought_threshold: float = 1.15
    
    # Risk Management
    profit_target_percent: float = 0.25
    stop_loss_percent: float = 0.05
    scaling_trigger_percent: float = 0.15
    scaling_increment_percent: float = 10.0
    
    # Time Management
    max_trade_duration_seconds: int = 90
    tick_interval_ms: int = 100  # 100ms latency target
    
    # Position Sizing
    vix_adjustment: bool = True
    vix_base: float = 20.0
    
    # Trading Hours (IST)
    morning_start: time = time(9, 45)
    morning_end: time = time(11, 30)
    afternoon_start: time = time(13, 30)
    afternoon_end: time = time(14, 45)

class IndexScalpingConfig:
    """Main configuration class for Index Scalping Strategy"""
    
    def __init__(self):
        # Dhan API Configuration
        self.dhan = DhanConfig()
        
        # Index Configurations
        self.indices = {
            "NIFTY": IndexConfig(
                symbol="NIFTY",
                exchange="NSE",
                lot_size=75,
                total_lots=20
            ),
            "BANKNIFTY": IndexConfig(
                symbol="BANKNIFTY",
                exchange="NSE",
                lot_size=35,
                total_lots=10
            ),
            "FINNIFTY": IndexConfig(
                symbol="FINNIFTY",
                exchange="NSE",
                lot_size=65,
                total_lots=15
            ),
            "SENSEX": IndexConfig(
                symbol="SENSEX", 
                exchange="BSE",
                lot_size=20,  # SENSEX lot size is 20 (as of Dec 2024)
                total_lots=50
            ),
            "BANKEX": IndexConfig(
                symbol="BANKEX",
                exchange="BSE",
                lot_size=30,
                total_lots=20
            ),
            "MIDCPNIFTY": IndexConfig(
                symbol="MIDCPNIFTY",
                exchange="NSE",
                lot_size=140,
                total_lots=10
            )
        }
        
        # Scalping Parameters
        self.scalping = ScalpingParameters()
        
        # Service Configuration
        self.service_port = int(os.getenv("INDEX_SCALPING_PORT", "8003"))
        self.service_host = os.getenv("INDEX_SCALPING_HOST", "0.0.0.0")
        
        # Risk Management
        self._max_daily_loss_percent = 3.0
        self._max_capital_per_trade_percent = 1.0
        
        # Paper Trading Configuration
        self.paper_trading_capital = 1000000.0  # ₹10 Lakh
        
        # Database Configuration
        self.db_path = "data/index_scalping.db"
        
        # Logging Configuration
        self.log_level = "INFO"
        self.log_file = "logs/index_scalping.log"
        
    def get_index_config(self, symbol: str) -> IndexConfig:
        """Get configuration for specific index"""
        if symbol.upper() not in self.indices:
            raise ValueError(f"Unsupported index: {symbol}")
        return self.indices[symbol.upper()]
    
    def is_trading_hours(self, current_time: time) -> bool:
        """Check if current time is within trading hours"""
        return (
            (self.scalping.morning_start <= current_time <= self.scalping.morning_end) or
            (self.scalping.afternoon_start <= current_time <= self.scalping.afternoon_end)
        )
    
    def calculate_vix_adjusted_lots(self, base_lots: int, current_vix: float) -> int:
        """Calculate VIX-adjusted position size"""
        if not self.scalping.vix_adjustment:
            return base_lots
            
        adjustment_factor = self.scalping.vix_base / max(current_vix, 1.0)
        return max(1, int(base_lots * adjustment_factor))
    
    @property
    def nifty_lot_size(self) -> int:
        """NIFTY lot size"""
        return self.indices["NIFTY"].lot_size
    
    @property 
    def nifty_default_lots(self) -> int:
        """NIFTY default lots"""
        return self.indices["NIFTY"].total_lots
    
    @property
    def sensex_lot_size(self) -> int:
        """SENSEX lot size"""
        return self.indices["SENSEX"].lot_size
    
    @property
    def sensex_default_lots(self) -> int:
        """SENSEX default lots"""
        return self.indices["SENSEX"].total_lots
    
    @property
    def max_capital_per_trade_percent(self) -> float:
        """Maximum capital per trade percentage"""
        return self._max_capital_per_trade_percent
    
    @property
    def max_daily_loss_percent(self) -> float:
        """Maximum daily loss percentage"""
        return self._max_daily_loss_percent

# Global configuration instance
config = IndexScalpingConfig()
