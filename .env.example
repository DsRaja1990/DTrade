# Environment Variables Template

# DhanHQ API Configuration
DHAN_CLIENT_ID=your_client_id_here
DHAN_ACCESS_TOKEN=your_access_token_here
DHAN_API_BASE_URL=https://api.dhan.co/v2
DHAN_FEED_URL=wss://api-feed.dhan.co

# Database Configuration
DATABASE_URL=sqlite:///./dtrade.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/dtrade

# Redis Configuration
REDIS_URL=redis://localhost:6379

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# Security
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AI Trading Configuration
AI_ENABLED=True
MAX_POSITION_SIZE=100000
MAX_DAILY_LOSS=50000
RISK_PERCENTAGE=2.0
TRAILING_STOP_PERCENTAGE=1.0

# Market Data Configuration
MARKET_DATA_ENABLED=True
HISTORICAL_DATA_ENABLED=True
LIVE_FEED_ENABLED=True

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/dtrade.log

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000/ws

# Email Configuration (Optional)
EMAIL_ENABLED=False
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Notification Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Trading Parameters
DEFAULT_QUANTITY=25
DEFAULT_PRODUCT_TYPE=INTRADAY
DEFAULT_ORDER_TYPE=MARKET
ENABLE_PAPER_TRADING=True

# Performance Configuration
CACHE_TTL=300
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=30
